{
  "name": "psicologia-saas",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/api && npm run build --workspace=apps/web",
    "db:ensure": "npm run ensure-db --workspace=packages/prisma",
    "db:migrate": "npm run migrate --workspace=packages/prisma",
    "db:generate": "npm run generate --workspace=packages/prisma",
    "db:studio": "npm run studio --workspace=packages/prisma",
    "kill:api": "lsof -ti :3001 | xargs kill -9 || true"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
